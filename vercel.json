{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "webgl-fluid.js",
      "use": "@vercel/static"
    },
    {
      "src": "config-love.json",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/webgl-fluid.js",
      "dest": "/webgl-fluid.js"
    },
    {
      "src": "/config-love.json",
      "dest": "/config-love.json"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
